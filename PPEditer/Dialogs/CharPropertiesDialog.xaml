<Window x:Class="PPEditer.Dialogs.CharPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_CharProps}"
        Width="400" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="10">

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Btn_Ok}"
                    Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="80" IsCancel="True" Click="OnCancel"/>
        </StackPanel>

        <TabControl>

            <!-- ── Tab 1: 글꼴 ── -->
            <TabItem Header="{DynamicResource Dlg_Char_Tab_Font}">
                <Grid Margin="12,10,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 글꼴 -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Dlg_Char_Font}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <ComboBox x:Name="CbFont" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                              IsEditable="True" Margin="0,6,0,6"/>

                    <!-- 크기 -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Dlg_Char_Size}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbSize" Grid.Row="1" Grid.Column="1" Margin="0,6,6,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="pt" VerticalAlignment="Center"/>

                    <!-- 간격 -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{DynamicResource Dlg_Char_Spacing}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbSpacing" Grid.Row="2" Grid.Column="1" Margin="0,6,6,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="1/100pt" VerticalAlignment="Center"/>

                    <!-- 전경색 -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="{DynamicResource Dlg_Char_ForeColor}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <Button x:Name="BtnForeColor" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                            Height="28" Margin="0,6,0,6" Click="OnPickFore"
                            Foreground="Transparent"/>

                    <!-- 배경색 -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="{DynamicResource Dlg_Char_BackColor}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <Button x:Name="BtnBackColor" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                            Height="28" Margin="0,6,0,6" Click="OnPickBack"
                            Foreground="Transparent"/>

                    <!-- 줄 색 -->
                    <TextBlock Grid.Row="5" Grid.Column="0"
                               Text="{DynamicResource Dlg_Char_UlColor}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <Button x:Name="BtnUlColor" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                            Height="28" Margin="0,6,0,6" Click="OnPickUl"
                            Foreground="Transparent"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: 스타일 ── -->
            <TabItem Header="{DynamicResource Dlg_Char_Tab_Style}">
                <StackPanel Margin="12,10,12,6">
                    <CheckBox x:Name="ChkBold"      Margin="0,4" Content="{DynamicResource Dlg_Char_Bold}"/>
                    <CheckBox x:Name="ChkItalic"    Margin="0,4" Content="{DynamicResource Dlg_Char_Italic}"/>
                    <CheckBox x:Name="ChkOutline"   Margin="0,4" Content="{DynamicResource Dlg_Char_Outline}"/>
                    <CheckBox x:Name="ChkUnderline" Margin="0,4" Content="{DynamicResource Dlg_Char_Underline}"/>
                    <CheckBox x:Name="ChkStrike"    Margin="0,4" Content="{DynamicResource Dlg_Char_Strike}"/>
                    <CheckBox x:Name="ChkOverline"  Margin="0,4" Content="{DynamicResource Dlg_Char_Overline}"/>

                    <GroupBox Header="{DynamicResource Dlg_Char_ScriptLabel}" Margin="0,8,0,4">
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <RadioButton x:Name="RbNone"  Content="{DynamicResource Dlg_Char_ScriptNone}"
                                         GroupName="Script" IsChecked="True" Margin="0,0,12,0"/>
                            <RadioButton x:Name="RbSuper" Content="{DynamicResource Dlg_Char_Super}"
                                         GroupName="Script" Margin="0,0,12,0"/>
                            <RadioButton x:Name="RbSub"   Content="{DynamicResource Dlg_Char_Sub}"
                                         GroupName="Script"/>
                        </StackPanel>
                    </GroupBox>

                    <TextBlock Text="{DynamicResource Dlg_Char_OverlineNote}"
                               FontSize="10" Foreground="Gray" Margin="0,8,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
