<Window x:Class="PPEditer.Dialogs.ParaPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_ParaProps}"
        Width="360" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="12">

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Btn_Ok}"
                    Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="80" IsCancel="True" Click="OnCancel"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 가로 정렬 -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_HorzAlign}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <ComboBox x:Name="CbHorzAlign" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                      Margin="0,6,0,6"/>

            <!-- 세로 정렬 -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_VertAnchor}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <ComboBox x:Name="CbVertAnchor" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                      Margin="0,6,0,6"/>

            <!-- separator row 2 -->

            <!-- 들여쓰기 -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_Indent}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="TbIndent" Grid.Row="3" Grid.Column="1" Margin="0,6,6,6"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

            <!-- 내어쓰기 -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_Hanging}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="TbHanging" Grid.Row="4" Grid.Column="1" Margin="0,6,6,6"/>
            <TextBlock Grid.Row="4" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

            <!-- separator row 5 -->

            <!-- 줄 간격 -->
            <TextBlock Grid.Row="6" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_LineSpacing}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="TbLineSpacing" Grid.Row="6" Grid.Column="1" Margin="0,6,6,6"/>
            <TextBlock Grid.Row="6" Grid.Column="2" Text="%" VerticalAlignment="Center"/>

            <!-- 문단 앞 간격 -->
            <TextBlock Grid.Row="7" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_SpaceBefore}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="TbSpaceBefore" Grid.Row="7" Grid.Column="1" Margin="0,6,6,6"/>
            <TextBlock Grid.Row="7" Grid.Column="2" Text="pt" VerticalAlignment="Center"/>

            <!-- 문단 뒤 간격 -->
            <TextBlock Grid.Row="8" Grid.Column="0"
                       Text="{DynamicResource Dlg_Para_SpaceAfter}"
                       VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="TbSpaceAfter" Grid.Row="8" Grid.Column="1" Margin="0,6,6,6"/>
            <TextBlock Grid.Row="8" Grid.Column="2" Text="pt" VerticalAlignment="Center"/>
        </Grid>
    </DockPanel>
</Window>
