<Window x:Class="PPEditer.Dialogs.TransitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_Transition}"
        Width="420" Height="400"
        MinHeight="320"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <!-- 버튼 행 — 항상 아래에 고정 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Btn_Ok}"     Width="70" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}" Width="70"
                    IsCancel="True"  Click="OnCancel"/>
        </StackPanel>

        <!-- 모든 슬라이드에 적용 체크박스 -->
        <CheckBox x:Name="ChkAllSlides"
                  Content="{DynamicResource Dlg_Transition_AllSlides}"
                  DockPanel.Dock="Bottom" Margin="0,6,0,0"/>

        <!-- 위쪽 레이블 -->
        <TextBlock Text="{DynamicResource Dlg_Transition_Select}"
                   DockPanel.Dock="Top"
                   FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- 목록이 남은 공간을 모두 차지 -->
        <ListBox x:Name="LbTransitions"
                 SelectionChanged="OnSelectionChanged">
            <ListBoxItem Tag="None"    Content="{DynamicResource Tr_None}"/>
            <ListBoxItem Tag="Fade"    Content="{DynamicResource Tr_Fade}"/>
            <ListBoxItem Tag="Push"    Content="{DynamicResource Tr_Push}"/>
            <ListBoxItem Tag="Wipe"    Content="{DynamicResource Tr_Wipe}"/>
            <ListBoxItem Tag="Flip"    Content="{DynamicResource Tr_Flip}"/>
            <ListBoxItem Tag="Crumple" Content="{DynamicResource Tr_Crumple}"/>
            <ListBoxItem Tag="Morph"   Content="{DynamicResource Tr_Morph}"/>
        </ListBox>
    </DockPanel>
</Window>
