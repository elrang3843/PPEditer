<Window x:Class="PPEditer.Dialogs.MathSymbolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_Math}"
        Width="600" Height="480"
        MinWidth="440" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <DockPanel Margin="8">

        <!-- Bottom: preview + close -->
        <Border DockPanel.Dock="Bottom" Margin="0,6,0,0"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0"
                Padding="0,6,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Btn_Close}"
                        Width="80" Click="OnClose"/>
                <TextBlock x:Name="TbInfo" VerticalAlignment="Center"
                           Margin="8,0" Foreground="{DynamicResource StatusFg}"
                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TbPreview"
                           FontSize="30" MinWidth="44" MaxWidth="60"
                           TextAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Cambria Math, Segoe UI Symbol, Arial Unicode MS"/>
            </DockPanel>
        </Border>

        <!-- Category tabs (built in code-behind) -->
        <TabControl x:Name="TabCtrl"/>

    </DockPanel>
</Window>
