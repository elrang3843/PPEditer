<Window x:Class="PPEditer.Dialogs.SlideShowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slide Show"
        WindowStyle="None"
        WindowState="Maximized"
        Background="Black"
        ShowInTaskbar="True"
        Topmost="True"
        Cursor="None"
        ContextMenu="{x:Null}"
        KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseLeft"
        MouseRightButtonDown="OnMouseRight">
    <Grid Background="Black">
        <Viewbox x:Name="SlideViewbox" Stretch="Uniform"/>
    </Grid>
</Window>
