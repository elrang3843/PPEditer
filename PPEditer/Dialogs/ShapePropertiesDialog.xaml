<Window x:Class="PPEditer.Dialogs.ShapePropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_ShapeProps}"
        Width="380" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="10">

        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Btn_Ok}"
                    Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="80" IsCancel="True" Click="OnCancel"/>
        </StackPanel>

        <TabControl>

            <!-- ── Tab 1: 위치 / 크기 ── -->
            <TabItem Header="{DynamicResource Dlg_ShapeTab_Pos}">
                <Grid Margin="12,10,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_Name}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                             IsReadOnly="True" Margin="0,6,0,6" Background="Transparent"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_X}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbX" Grid.Row="1" Grid.Column="1" Margin="0,6,6,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_Y}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbY" Grid.Row="2" Grid.Column="1" Margin="0,6,6,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_W}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbCx" Grid.Row="3" Grid.Column="1" Margin="0,6,6,6"
                             TextChanged="TbCx_TextChanged"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_H}"
                               VerticalAlignment="Center" Margin="0,6,10,6"/>
                    <TextBox x:Name="TbCy" Grid.Row="4" Grid.Column="1" Margin="0,6,6,6"
                             TextChanged="TbCy_TextChanged"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

                    <CheckBox x:Name="ChkLockAspect" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
                              Content="{DynamicResource Dlg_ShapeProps_LockAspect}"
                              Margin="0,8,0,4"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: 채우기 ── -->
            <TabItem Header="{DynamicResource Dlg_ShapeTab_Fill}">
                <Grid Margin="12,10,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_FillType}"
                               VerticalAlignment="Center" Margin="0,8,10,8"/>
                    <ComboBox x:Name="CbFillKind" Grid.Row="0" Grid.Column="1"
                              Margin="0,8,0,8" SelectionChanged="OnFillKindChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_FillColor}"
                               VerticalAlignment="Center" Margin="0,8,10,8"/>
                    <Button x:Name="BtnFillColor" Grid.Row="1" Grid.Column="1"
                            Height="30" Margin="0,8,0,8" Click="OnPickFillColor"
                            Foreground="Transparent"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 3: 테두리 ── -->
            <TabItem Header="{DynamicResource Dlg_ShapeTab_Outline}">
                <Grid Margin="12,10,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_LineType}"
                               VerticalAlignment="Center" Margin="0,8,10,8"/>
                    <ComboBox x:Name="CbOutlineKind" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                              Margin="0,8,0,8" SelectionChanged="OnOutlineKindChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_LineWidth}"
                               VerticalAlignment="Center" Margin="0,8,10,8"/>
                    <TextBox x:Name="TbLineWidth" Grid.Row="1" Grid.Column="1" Margin="0,8,6,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="pt" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{DynamicResource Dlg_ShapeProps_LineColor}"
                               VerticalAlignment="Center" Margin="0,8,10,8"/>
                    <Button x:Name="BtnOutlineColor" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                            Height="30" Margin="0,8,0,8" Click="OnPickOutlineColor"
                            Foreground="Transparent"/>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
