<Window x:Class="PPEditer.Dialogs.ShapePropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_ShapeProps}"
        Width="320" Height="272"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="14">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource Btn_Ok}"
                    Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="80" IsCancel="True" Click="OnCancel"/>
        </StackPanel>

        <!-- Fields -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{DynamicResource Dlg_ShapeProps_Name}"
                       VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="TbName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                     IsReadOnly="True" Margin="0,5,0,5"
                     Background="Transparent"/>

            <!-- X -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="{DynamicResource Dlg_ShapeProps_X}"
                       VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="TbX" Grid.Row="1" Grid.Column="1" Margin="0,5,6,5"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

            <!-- Y -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="{DynamicResource Dlg_ShapeProps_Y}"
                       VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="TbY" Grid.Row="2" Grid.Column="1" Margin="0,5,6,5"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

            <!-- Width -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="{DynamicResource Dlg_ShapeProps_W}"
                       VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="TbCx" Grid.Row="3" Grid.Column="1" Margin="0,5,6,5"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>

            <!-- Height -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="{DynamicResource Dlg_ShapeProps_H}"
                       VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="TbCy" Grid.Row="4" Grid.Column="1" Margin="0,5,6,5"/>
            <TextBlock Grid.Row="4" Grid.Column="2" Text="cm" VerticalAlignment="Center"/>
        </Grid>
    </DockPanel>
</Window>
