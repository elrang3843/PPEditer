<Window x:Class="PPEditer.Dialogs.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_License}"
        Width="620" Height="600"
        MinWidth="480" MinHeight="400"
        WindowStyle="ThreeDBorderWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Padding="12,8,12,12">
            <Button Content="{DynamicResource Btn_Close}" Width="80"
                    HorizontalAlignment="Right"
                    IsCancel="True" Click="OnClose"/>
        </Border>
        <ScrollViewer x:Name="ContentArea"
                      Padding="24,18,24,18"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"/>
    </DockPanel>
</Window>
