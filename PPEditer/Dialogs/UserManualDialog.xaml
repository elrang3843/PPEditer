<Window x:Class="PPEditer.Dialogs.UserManualDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_UserManual}"
        Width="720" Height="540"
        MinWidth="520" MinHeight="400"
        WindowStyle="ThreeDBorderWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- 닫기 버튼 -->
        <Border DockPanel.Dock="Bottom" Padding="12,8,12,12">
            <Button Content="{DynamicResource Btn_Close}" Width="80"
                    HorizontalAlignment="Right"
                    IsCancel="True" Click="OnClose"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="155"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 목차 -->
            <ListBox x:Name="NavList"
                     Grid.Column="0"
                     BorderThickness="0,0,1,0"
                     SelectionChanged="OnNavChanged"
                     FontSize="13"/>

            <!-- 오른쪽 내용 -->
            <ScrollViewer x:Name="ContentArea"
                          Grid.Column="1"
                          Padding="24,18,24,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"/>
        </Grid>
    </DockPanel>
</Window>
