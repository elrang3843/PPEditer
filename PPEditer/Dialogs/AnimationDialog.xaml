<Window x:Class="PPEditer.Dialogs.AnimationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_Animation}"
        Width="420" Height="460"
        MinHeight="380"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <!-- 버튼 행 — 항상 아래에 고정 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Btn_Ok}"     Width="70" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}" Width="70"
                    IsCancel="True"  Click="OnCancel"/>
        </StackPanel>

        <!-- 자동 실행 체크박스 -->
        <CheckBox x:Name="ChkAutoPlay"
                  Content="{DynamicResource Dlg_AutoPlay}"
                  DockPanel.Dock="Bottom" Margin="0,6,0,0"/>

        <!-- 반복 횟수 -->
        <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="18"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Dlg_RepeatCount}"
                       VerticalAlignment="Center"/>
            <TextBox   Grid.Column="1" x:Name="TbRepeat" Text="1"
                       HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
            <StackPanel Grid.Column="2" Margin="2,0,0,0">
                <RepeatButton Content="▲" Height="13" FontSize="8" Focusable="False" Click="OnRepUp"/>
                <RepeatButton Content="▼" Height="13" FontSize="8" Focusable="False" Click="OnRepDown"/>
            </StackPanel>
        </Grid>

        <!-- 시간 설정 -->
        <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="18"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Dlg_Duration}"
                       VerticalAlignment="Center"/>
            <TextBox   Grid.Column="1" x:Name="TbDuration" Text="0.5"
                       HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
            <StackPanel Grid.Column="2" Margin="2,0,0,0">
                <RepeatButton Content="▲" Height="13" FontSize="8" Focusable="False" Click="OnDurUp"/>
                <RepeatButton Content="▼" Height="13" FontSize="8" Focusable="False" Click="OnDurDown"/>
            </StackPanel>
        </Grid>

        <!-- 위쪽 레이블 -->
        <TextBlock Text="{DynamicResource Dlg_Animation_Select}"
                   DockPanel.Dock="Top"
                   FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- 목록이 남은 공간을 모두 차지 -->
        <ListBox x:Name="LbAnimations">
            <ListBoxItem Tag="None"   Content="{DynamicResource An_None}"/>
            <ListBoxItem Tag="FadeIn" Content="{DynamicResource An_FadeIn}"/>
            <ListBoxItem Tag="FlyIn"  Content="{DynamicResource An_FlyIn}"/>
            <ListBoxItem Tag="Pulse"  Content="{DynamicResource An_Pulse}"/>
            <ListBoxItem Tag="Bounce" Content="{DynamicResource An_Bounce}"/>
            <ListBoxItem Tag="WipeIn" Content="{DynamicResource An_WipeIn}"/>
        </ListBox>
    </DockPanel>
</Window>
