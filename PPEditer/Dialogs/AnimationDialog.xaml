<Window x:Class="PPEditer.Dialogs.AnimationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_Animation}"
        Width="400" Height="320"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12">
        <TextBlock Text="{DynamicResource Dlg_Animation_Select}"
                   FontWeight="Bold" Margin="0,0,0,8"/>
        <ListBox x:Name="LbAnimations" Height="200" Margin="0,0,0,16">
            <ListBoxItem Tag="None"    Content="{DynamicResource An_None}"/>
            <ListBoxItem Tag="FadeIn"  Content="{DynamicResource An_FadeIn}"/>
            <ListBoxItem Tag="FlyIn"   Content="{DynamicResource An_FlyIn}"/>
            <ListBoxItem Tag="Pulse"   Content="{DynamicResource An_Pulse}"/>
            <ListBoxItem Tag="Bounce"  Content="{DynamicResource An_Bounce}"/>
            <ListBoxItem Tag="WipeIn"  Content="{DynamicResource An_WipeIn}"/>
        </ListBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Ok}"     Width="70" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}" Width="70"
                    IsCancel="True"  Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
