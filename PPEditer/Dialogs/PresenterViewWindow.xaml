<Window x:Class="PPEditer.Dialogs.PresenterViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_PresenterView}"
        Background="#16213E"
        Foreground="White"
        ShowInTaskbar="True"
        KeyDown="OnKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 슬라이드 영역 -->
            <RowDefinition Height="*"/>
            <!-- 컨트롤 바 -->
            <RowDefinition Height="46"/>
            <!-- 노트 영역 -->
            <RowDefinition Height="200" MinHeight="100" MaxHeight="380"/>
        </Grid.RowDefinitions>

        <!-- ══ 슬라이드 영역 ════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <!-- 현재 슬라이드 (넓게) -->
                <ColumnDefinition Width="2.2*"/>
                <!-- 다음 슬라이드 + 슬라이드 번호 -->
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- 현재 슬라이드 -->
            <Border x:Name="CurrentSlideBorder"
                    Grid.Column="0" Margin="10,10,5,10"
                    Background="#0D0D1A"
                    BorderBrush="#2E4080" BorderThickness="2"
                    CornerRadius="3"/>

            <!-- 오른쪽 패널 -->
            <DockPanel Grid.Column="1" Margin="5,10,10,10">

                <!-- "다음 슬라이드" 레이블 -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource Lbl_NextSlide}"
                           Foreground="#6680CC" FontSize="11"
                           Margin="2,0,0,4"/>

                <!-- 슬라이드 번호 -->
                <TextBlock x:Name="SlideCountText"
                           DockPanel.Dock="Bottom"
                           Foreground="White" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                <!-- 다음 슬라이드 미리보기 -->
                <Border x:Name="NextSlideBorder"
                        Background="#0D0D1A"
                        BorderBrush="#2A2A4C" BorderThickness="1"
                        CornerRadius="2"/>
            </DockPanel>
        </Grid>

        <!-- ══ 컨트롤 바 ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0D1226" BorderBrush="#1E2E60" BorderThickness="0,1,0,1">
            <Grid>
                <!-- 이전 / 다음 버튼 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnPrev" Width="90" Height="30" Margin="8,0"
                            Content="{DynamicResource Btn_PresenterPrev}"
                            Click="OnPrev" Cursor="Hand"
                            Background="#1E2E5A" Foreground="White" BorderBrush="#3A5090"
                            FontSize="13"/>
                    <Button x:Name="BtnNext" Width="90" Height="30" Margin="8,0"
                            Content="{DynamicResource Btn_PresenterNext}"
                            Click="OnNext" Cursor="Hand"
                            Background="#1E2E5A" Foreground="White" BorderBrush="#3A5090"
                            FontSize="13"/>
                </StackPanel>

                <!-- 경과 시간 -->
                <TextBlock x:Name="TimerText"
                           Foreground="#44FF88" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,20,0"
                           FontFamily="Consolas, Courier New"/>
            </Grid>
        </Border>

        <!-- ══ 발표자 노트 영역 ══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#0D1226"
                BorderBrush="#1E2E60" BorderThickness="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <TextBlock Grid.Row="0"
                           Text="{DynamicResource Lbl_PresenterNotes}"
                           Foreground="#6680CC" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0"/>

                <!-- 노트 텍스트 -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14,2,14,10">
                    <TextBlock x:Name="NotesText"
                               Foreground="#C8D4FF" FontSize="15"
                               TextWrapping="Wrap" LineHeight="26"
                               FontFamily="맑은 고딕, Segoe UI"/>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</Window>
