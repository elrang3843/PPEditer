<Window x:Class="PPEditer.Dialogs.TemplatePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_TemplatePickTitle}"
        Width="560" Height="400"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <DockPanel Margin="16">

        <!-- Buttons row -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BrowseBtn"
                    Content="{DynamicResource Dlg_Template_Browse}"
                    Width="160" Margin="0,0,8,0"
                    Click="OnBrowse"/>
            <Button x:Name="CreateBtn"
                    Content="{DynamicResource Dlg_Template_Create}"
                    Width="160" Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnCreate"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="80"
                    IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>

        <!-- Folder label -->
        <TextBlock DockPanel.Dock="Top"
                   x:Name="FolderLabel"
                   Foreground="#888888" FontSize="11"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,8"/>

        <!-- Template list -->
        <Border BorderBrush="#CCCCCC" BorderThickness="1">
            <Grid>
                <!-- Empty state message -->
                <TextBlock x:Name="NoTemplatesText"
                           Text="{DynamicResource Dlg_Template_NoTemplates}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="#AAAAAA" FontSize="13"
                           Visibility="Collapsed"/>

                <ListBox x:Name="TemplateList"
                         BorderThickness="0"
                         SelectionMode="Single"
                         MouseDoubleClick="OnListDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📄" FontSize="14"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FileName}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Modified}"
                                           Foreground="#888888" FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="12,0,4,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </DockPanel>
</Window>
