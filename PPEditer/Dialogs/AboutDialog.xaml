<Window x:Class="PPEditer.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PPEditer 정보"
        Width="460" Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 아이콘 + 텍스트 가로 배치 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 아이콘 128×128 -->
            <Image Grid.Column="0"
                   Source="/PPEditer;component/Resources/PPEditor_128.png"
                   Width="128" Height="128"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- 텍스트 영역 -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="PPEditer"
                           FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock Text="Planning Proposal Editor"
                           FontSize="11" Foreground="#666666" Margin="0,0,0,12"/>
                <TextBlock Text="버전 1.0.0" Margin="0,0,0,4"/>
                <TextBlock Text="회사: HANDTECH (핸텍) — 상상공작소" Margin="0,2"/>
                <TextBlock Text="저작권자: 노진문 (Noh JinMoon)" Margin="0,2"/>
                <TextBlock Text="라이선스: MIT License" Margin="0,2"/>
                <TextBlock Text="Copyright © 2026 Noh JinMoon"
                           Margin="0,6,0,0" Foreground="#666666" FontSize="11"/>
            </StackPanel>
        </Grid>

        <Button Grid.Row="1" Content="확인" Width="80" HorizontalAlignment="Center"
                Margin="0,16,0,0"
                IsDefault="True" Click="OkButton_Click"/>
    </Grid>
</Window>
