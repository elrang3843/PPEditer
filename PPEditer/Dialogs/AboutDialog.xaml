<Window x:Class="PPEditer.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PPEditer 정보"
        Width="400" Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PPEditer"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Planning Proposal Editor"
                   FontSize="11" HorizontalAlignment="Center" Foreground="#666666"/>

        <StackPanel Grid.Row="3" HorizontalAlignment="Center" TextBlock.TextAlignment="Center">
            <TextBlock Text="버전 1.0.0" Margin="0,0,0,6"/>
            <TextBlock Text="회사: HANDTECH (핸텍) — 상상공작소" Margin="0,2"/>
            <TextBlock Text="저작권자: 노진문 (Noh JinMoon)" Margin="0,2"/>
            <TextBlock Text="라이선스: MIT License" Margin="0,2"/>
            <TextBlock Text="Copyright © 2026 Noh JinMoon" Margin="0,6,0,0" Foreground="#666666" FontSize="11"/>
        </StackPanel>

        <Button Grid.Row="5" Content="확인" Width="80" HorizontalAlignment="Center"
                IsDefault="True" Click="OkButton_Click"/>
    </Grid>
</Window>
