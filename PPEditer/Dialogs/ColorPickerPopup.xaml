<Window x:Class="PPEditer.Dialogs.ColorPickerPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=" "
        Width="192" Height="148"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual">
    <StackPanel Margin="6">
        <UniformGrid x:Name="ColorGrid" Rows="4" Columns="6" Margin="0,0,0,6"/>
        <DockPanel Margin="0,0,0,6">
            <Border x:Name="PreviewSwatch" Width="24" Height="24"
                    BorderBrush="Gray" BorderThickness="1"
                    DockPanel.Dock="Left" Margin="0,0,6,0"/>
            <TextBlock Text="#" VerticalAlignment="Center" Margin="0,0,2,0"/>
            <TextBox x:Name="TbHex" MaxLength="6" DockPanel.Dock="Right" Width="70"
                     HorizontalAlignment="Right" Margin="4,0,0,0"
                     TextChanged="OnHexTextChanged"/>
            <TextBlock VerticalAlignment="Center" Text="hex"/>
        </DockPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Ok}"     Width="60" Margin="0,0,6,0"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}" Width="60"
                    IsCancel="True" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
