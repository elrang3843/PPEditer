<Window x:Class="PPEditer.Dialogs.PrintLayoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_Print}"
        Width="320" Height="270"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">

        <!-- 버튼 행 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource Btn_Print}"  Width="80" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="{DynamicResource Btn_Cancel}" Width="80"
                    IsCancel="True" Click="OnCancel"/>
        </StackPanel>

        <!-- 내용 -->
        <StackPanel>
            <TextBlock Text="{DynamicResource Dlg_Print_Layout}"
                       FontWeight="SemiBold" Margin="0,0,0,8"/>
            <RadioButton x:Name="RbSlideOnly"
                         Content="{DynamicResource Dlg_Print_SlideOnly}"
                         GroupName="Layout" IsChecked="True" Margin="4,0,0,5"/>
            <RadioButton x:Name="RbSlideNotes"
                         Content="{DynamicResource Dlg_Print_SlideNotes}"
                         GroupName="Layout" Margin="4,0,0,5"/>
            <RadioButton x:Name="RbHandout3"
                         Content="{DynamicResource Dlg_Print_Handout3}"
                         GroupName="Layout" Margin="4,0,0,16"/>

            <Separator Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource Dlg_Print_Options}"
                       FontWeight="SemiBold" Margin="0,0,0,8"/>
            <CheckBox x:Name="ChkBW"
                      Content="{DynamicResource Dlg_Print_BlackWhite}"
                      Margin="4,0,0,0"/>
        </StackPanel>

    </DockPanel>
</Window>
