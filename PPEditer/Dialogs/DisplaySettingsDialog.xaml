<Window x:Class="PPEditer.Dialogs.DisplaySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Dlg_DisplaySettings}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="맑은 고딕, Segoe UI" FontSize="13">

    <StackPanel Margin="20">

        <!-- Presentation monitor -->
        <TextBlock Text="{DynamicResource Lbl_ShowMonitor}" Margin="0,0,0,4"/>
        <ComboBox x:Name="ShowMonitorCombo" Margin="0,0,0,14" Padding="6,4"/>

        <!-- Presenter monitor -->
        <TextBlock Text="{DynamicResource Lbl_PresenterMonitor}" Margin="0,0,0,4"/>
        <ComboBox x:Name="PresenterMonitorCombo" Margin="0,0,0,20" Padding="6,4"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인"
                    Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OnOK"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="80" IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>

    </StackPanel>
</Window>
