<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>PPEditer</RootNamespace>
    <AssemblyName>PPEditer</AssemblyName>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Resources\PPEditor.ico</ApplicationIcon>
    <Copyright>Copyright © 2026 Noh JinMoon (HANDTECH)</Copyright>
    <Company>HANDTECH - 상상공작소</Company>
    <Authors>Noh JinMoon</Authors>
    <Version>1.9.0</Version>
    <Platforms>AnyCPU</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft Open XML SDK — MIT License -->
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.2.0" />
    <!-- PDFsharp — MIT License -->
    <PackageReference Include="PDFsharp" Version="6.1.1" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\**\*" />
  </ItemGroup>

</Project>
