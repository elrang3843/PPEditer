<Application x:Class="PPEditer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme loaded first; strings loaded second (higher priority) -->
                <ResourceDictionary Source="Resources/Theme.Light.xaml"/>
                <ResourceDictionary Source="Resources/Strings.ko.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Base font styles (not in theme files, always applied) -->
            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontFamily" Value="맑은 고딕, Segoe UI, Sans-Serif"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="맑은 고딕, Segoe UI, Sans-Serif"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
