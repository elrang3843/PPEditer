<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ Named brushes ════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="CanvasBg"       Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelHeaderBg"  Color="#2D2D2D"/>
    <SolidColorBrush x:Key="PanelHeaderFg"  Color="#C8C8C8"/>
    <SolidColorBrush x:Key="PanelBg"        Color="#252526"/>
    <SolidColorBrush x:Key="ThumbFg"        Color="#A0A0A0"/>
    <SolidColorBrush x:Key="AppFg"          Color="#D4D4D4"/>
    <SolidColorBrush x:Key="StatusBg"       Color="#007ACC"/>
    <SolidColorBrush x:Key="StatusFg"       Color="White"/>

    <!-- ══ Implicit styles — applied globally in dark theme ════════════ -->

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource StatusBg}"/>
        <Setter Property="Foreground" Value="{StaticResource StatusFg}"/>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="#2D2D2D"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="#2D2D2D"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
    </Style>

    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="#2D2D2D"/>
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="#2D2D2D"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="맑은 고딕, Segoe UI, Sans-Serif"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#D4D4D4"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#3C3C3C"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="#3C3C3C"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
        <Setter Property="BorderBrush" Value="#555555"/>
    </Style>

    <Style TargetType="ToggleButton">
        <Setter Property="Background" Value="#3C3C3C"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
        <Setter Property="BorderBrush" Value="#555555"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="맑은 고딕, Segoe UI, Sans-Serif"/>
        <Setter Property="Foreground" Value="#D4D4D4"/>
    </Style>

    <Style TargetType="Window">
        <Setter Property="Background" Value="#252526"/>
    </Style>

</ResourceDictionary>
