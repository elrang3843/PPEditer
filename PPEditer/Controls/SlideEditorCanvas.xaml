<UserControl x:Class="PPEditer.Controls.SlideEditorCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CanvasBg}">
    <Grid>
        <ScrollViewer x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource CanvasBg}"
                      Focusable="False">
            <Grid x:Name="CenterGrid"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Margin="40">
                <!-- Drop shadow -->
                <Border Background="#80000000" Margin="4,4,-4,-4"/>

                <!-- Slide border -->
                <Border x:Name="SlideBorder"
                        BorderBrush="#AAAAAA" BorderThickness="1"
                        Background="White">
                    <Grid>
                        <Viewbox x:Name="SlideViewbox" Stretch="Uniform">
                            <Canvas x:Name="SlideCanvas" Width="960" Height="540"/>
                        </Viewbox>
                        <!-- Watermark overlay — same Stretch=Uniform so it scales with the slide -->
                        <ContentControl x:Name="WatermarkHost"
                                        IsHitTestVisible="False" Focusable="False"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"/>
                        <!-- Editor overlay — outside Viewbox so the RichTextBox renders at
                             physical screen pixels and the caret is never sub-pixel. -->
                        <Canvas x:Name="EditorOverlay"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- No-document overlay -->
        <TextBlock x:Name="NoDocMsg"
                   Text="{DynamicResource NoDoc}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#CCCCCC" FontSize="20"/>
    </Grid>
</UserControl>
