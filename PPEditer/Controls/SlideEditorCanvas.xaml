<UserControl x:Class="PPEditer.Controls.SlideEditorCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#646464">
    <Grid>
        <ScrollViewer x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#646464"
                      Focusable="False">
            <!-- Outer container centres the slide inside the scroll area -->
            <Grid x:Name="CenterGrid" HorizontalAlignment="Center" VerticalAlignment="Center"
                  Margin="40">

                <!-- Drop shadow -->
                <Border Background="#80000000" Margin="4,4,-4,-4"/>

                <!-- Slide border + viewbox -->
                <Border x:Name="SlideBorder"
                        BorderBrush="#AAAAAA" BorderThickness="1"
                        Background="White">
                    <Viewbox x:Name="SlideViewbox" Stretch="Uniform">
                        <!-- Slide canvas is injected here in code-behind -->
                        <Canvas x:Name="SlideCanvas" Width="960" Height="540"/>
                    </Viewbox>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- No-document message -->
        <TextBlock x:Name="NoDocMsg"
                   Text="파일을 여세요 (Ctrl+O)"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#CCCCCC" FontSize="20"/>
    </Grid>
</UserControl>
